{
  "name": "catch-it",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "vite --host",
    "dev": "vite --host",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\" --names \"web,server\" --prefix-colors \"blue,green\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "server": "node --experimental-vm-modules --loader ts-node/esm server/index.ts",
    "gtfs:process": "node scripts/process-gtfs.mjs",
    "icons:generate": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.8",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.15.0",
    "gtfs-realtime-bindings": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.1",
    "uuid": "^11.0.3",
    "workbox-core": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-window": "^7.3.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^0.21.1",
    "workbox-build": "^7.3.0"
  }
}
